{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylinktree.local/contracts/site-config.schema.json",
  "title": "SiteConfig",
  "type": "object",
  "required": ["profile", "links", "theme", "meta"],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "type": "object",
      "required": ["name", "handle", "bio", "avatarUrl"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "handle": { "type": "string", "minLength": 1, "maxLength": 30 },
        "bio": { "type": "string", "minLength": 1, "maxLength": 240 },
        "avatarUrl": { "type": "string", "minLength": 1 }
      }
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "icon"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1, "maxLength": 60 },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "icon": { "type": "string", "minLength": 1 },
          "highlighted": { "type": "boolean" }
        }
      }
    },
    "theme": {
      "type": "object",
      "required": [
        "background",
        "surface",
        "primary",
        "text",
        "mutedText",
        "buttonStyle"
      ],
      "additionalProperties": false,
      "properties": {
        "background": { "type": "string", "minLength": 1 },
        "surface": { "type": "string", "minLength": 1 },
        "primary": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "mutedText": { "type": "string", "minLength": 1 },
        "buttonStyle": {
          "type": "string",
          "enum": ["solid", "outline", "soft"]
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["title", "description"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 70 },
        "description": { "type": "string", "minLength": 1, "maxLength": 160 },
        "ogImage": { "type": "string", "minLength": 1 }
      }
    }
  }
}
